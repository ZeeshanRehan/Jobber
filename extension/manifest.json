{
  "manifest_version": 3,
  "name": "Jobber",
  "version": "1.0",
  "description": "Share jobs with your squad in one click",
  "permissions": ["activeTab", "storage"],
  "content_scripts": [
    {
      "matches": [
              "*://*.myworkdayjobs.com/*",
              "*://*.greenhouse.io/*",
              "*://*.lever.co/*",
              "*://*.ashbyhq.com/*",
              "*://*.rippling.com/*",
              "*://*.jobvite.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}